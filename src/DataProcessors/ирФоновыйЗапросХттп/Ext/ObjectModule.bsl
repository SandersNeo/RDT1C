Функция ОбработатьОтвет(Форма) Экспорт
	Если Ложь
		Или мОписаниеЗадания = Неопределено
		Или мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.Отменено
	Тогда
		мОписаниеЗадания = Неопределено;
		Возврат "";
	КонецЕсли; 
	ТелоОтвета = СокрЛ(ПрочитатьЧастьОтвета());
	ЛиПотокЗавершен = Не мЛиПотоковый Или ЛиПотокЗавершен();
	ПрефиксЧастиОтвета = "data: ";
	Если ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "Ошибка:") Тогда
		мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно;
	Иначе
		Если ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "Отмена:") Тогда
			// Только для потокового режима
		ИначеЕсли ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, "Конец:") Тогда
			// Только для потокового режима
			ТелоОтвета = "";
		ИначеЕсли Ложь
			Или ирОбщий.СтрНачинаетсяСЛкс(ТелоОтвета, ПрефиксЧастиОтвета)
			Или Найти(ТелоОтвета, Символы.ПС + ПрефиксЧастиОтвета)
		Тогда
			ТекстовыйДокумент = Новый ТекстовыйДокумент;
			ТекстовыйДокумент.УстановитьТекст(ТелоОтвета);
			Результат = Новый Массив;
			Для НомерСтроки = 1 По ТекстовыйДокумент.КоличествоСтрок() Цикл
				СтрокаТекста = ТекстовыйДокумент.ПолучитьСтроку(НомерСтроки);
				Если ирОбщий.СтрНачинаетсяСЛкс(СтрокаТекста, ПрефиксЧастиОтвета) Тогда
					ТекстБезПервогоФрагмента = ирОбщий.ТекстБезПервогоФрагментаЛкс(СтрокаТекста, ПрефиксЧастиОтвета);
					Если ТекстБезПервогоФрагмента = "[DONE]" Тогда
						// openrouter.ai
						ЛиПотокЗавершен = Истина;
						Прервать;
					КонецЕсли;
					ЭлементСообщения = ирОбщий.ОбъектИзТекстаЖСОНЛкс(ТекстБезПервогоФрагмента);
					Если ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "content_delta") <> Неопределено Тогда
						// Напарник потоковый
						ВложеннаяЧасть = ЭлементСообщения.content_delta;
						Результат.Добавить(ВложеннаяЧасть.content);
						Если ирОбщий.СвойствоСтруктурыЛкс(ВложеннаяЧасть, "tool_calls") <> Неопределено Тогда
							ПрочитатьЧастьДопзапросов(ВложеннаяЧасть);
							Если ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "finished") = Истина Тогда
								// вызов инструментов — если ИИ вернул вызов инструмента, выполняем и продолжаем диалог
								Если ОбработатьВызовИнструмента(мНакопленныйЗапрос, ЭлементСообщения.uuid) Тогда
									ЛиПотокЗавершен = Ложь;
								КонецЕсли;
								мНакопленныйЗапрос = Неопределено;
							КонецЕсли;
						КонецЕсли;
					ИначеЕсли ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "content") <> Неопределено Тогда
						// Напарник непотоковый
						Если ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения, "finished") = Истина Тогда
							ЛиПотокЗавершен = Истина;
						КонецЕсли;
					ИначеЕсли Истина
						И ЭлементСообщения.Свойство("choices") 
						И ЭлементСообщения.choices.Количество() > 0
					Тогда
						// openrouter.ai
						ВложеннаяЧасть = ЭлементСообщения.choices[0].delta;
						Если ВложеннаяЧасть.Свойство("content") Тогда
							ЧастьОтвета = ВложеннаяЧасть.content;
							//ЧастьОтвета = ВложеннаяЧасть.reasoning;
							Результат.Добавить(ЧастьОтвета);
						КонецЕсли;
						Если ВложеннаяЧасть.Свойство("tool_calls") Тогда
							ПрочитатьЧастьДопзапросов(ВложеннаяЧасть);
						КонецЕсли;
						Если Истина
							И мНакопленныйЗапрос <> Неопределено
							И ирОбщий.СвойствоСтруктурыЛкс(ЭлементСообщения.choices[0], "finish_reason") = "tool_calls" 
						Тогда
							// вызов инструментов — если ИИ вернул вызов инструмента, выполняем и продолжаем диалог
							Если ОбработатьВызовИнструмента(мНакопленныйЗапрос, ЭлементСообщения.id) Тогда
								ЛиПотокЗавершен = Ложь;
							КонецЕсли;
							мНакопленныйЗапрос = Неопределено;
						КонецЕсли;
					КонецЕсли;
				КонецЕсли;
			КонецЦикла;
			ТелоОтвета = ирОбщий.СтрСоединитьЛкс(Результат, "");
			мНакопленныйОтвет = мНакопленныйОтвет + ТелоОтвета;
		Иначе
			Если ирОбщий.ЛиТекстJSONЛкс(ТелоОтвета) Тогда
				ОтветЖСОН = ирОбщий.ОбъектИзТекстаЖСОНЛкс(ТелоОтвета);
				Если Истина
					И ОтветЖСОН.Свойство("choices")
					И ОтветЖСОН.choices.Количество() > 0
				Тогда
					// сайта openrouter.ai
					// вызов инструментов — если ИИ вернул вызов инструмента, выполняем и продолжаем диалог
					Если ОтветЖСОН.choices[0].message.Свойство("tool_calls") Тогда
						Если ОбработатьВызовИнструмента(ОтветЖСОН.choices[0].message) Тогда
							ЛиПотокЗавершен = Ложь;
						КонецЕсли;
					КонецЕсли;
					мНакопленныйОтвет = ОтветЖСОН.choices[0].message.content; // Строка
				Иначе
					мНакопленныйОтвет = "";
				КонецЕсли;
			КонецЕсли;
		КонецЕсли;
		Если ЛиПотокЗавершен Тогда
			мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.Завершено;
		КонецЕсли;
	КонецЕсли; 
	Если Истина
		И ЛиПотокЗавершен
		И мКонтекстВызоваИнструментов.Дозапросы.Количество() > 0
	Тогда
		мНакопленныйОтвет = мНакопленныйОтвет + Символы.ПС + Символы.ПС + "== Все выполенные дозапросы:" + Символы.ПС;
		Для каждого Дозапрос Из мКонтекстВызоваИнструментов.Дозапросы Цикл
			ВывестиДозапросВТекст(Дозапрос);
		КонецЦикла;
	КонецЕсли;
	мОписаниеЗадания.Параметры.Вставить("Ответ", мНакопленныйОтвет);
	Если ЛиПотокЗавершен Тогда
		Если мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.ЗавершеноАварийно Тогда
			Если мЛиПроверочный Тогда
				ирОбщий.СообщитьЛкс(ТелоОтвета,,,, Ложь);
			Иначе
				мОписаниеЗадания.Параметры.Ответ = мОписаниеЗадания.Параметры.Ответ + Символы.ПС + ТелоОтвета;
			КонецЕсли;
		КонецЕсли;
		ирКлиент.ОбработатьЗавершениеЗаданияФормыЛкс(мОписаниеЗадания, Форма,,,, мОписаниеЗадания.Параметры);
		Длительность = ТекущаяДата() - мОписаниеЗадания.НачалоВыполнения;
		Если Истина
			И Не мЛиПотоковый
			И (Ложь
				Или мЛиПроверочный И мОписаниеЗадания.Состояние = СостояниеФоновогоЗадания.Завершено
				Или мЛиПроверочный И Длительность > 1
				Или Длительность > 5)
		Тогда
			ирОбщий.СообщитьЛкс("ИИ ответил за " + Длительность + " секунд",,, Истина, Ложь);
		КонецЕсли;
		мОписаниеЗадания = Неопределено;
	Иначе
		Если мОписаниеЗадания.ОбработчикЗавершения <> "" Тогда
			Состояние = мОписаниеЗадания.Состояние;
			Параметры = мОписаниеЗадания.Параметры;
			Выполнить("Форма." + мОписаниеЗадания.ОбработчикЗавершения + "(Состояние, Параметры)");
		КонецЕсли;
	КонецЕсли;
	Возврат мНакопленныйОтвет;
КонецФункции

Процедура ПрочитатьЧастьДопзапросов(Знач ЧастьСообщения) Экспорт
	Если мНакопленныйЗапрос = Неопределено Тогда
		мНакопленныйЗапрос = ЧастьСообщения;
	Иначе
		Для Каждого ЧастьДозапроса Из ЧастьСообщения.tool_calls Цикл
			Если мНакопленныйЗапрос.tool_calls.ВГраница() < ЧастьДозапроса.index Тогда
				мНакопленныйЗапрос.tool_calls.Добавить(ЧастьДозапроса);
			КонецЕсли;
			мНакопленныйЗапрос.tool_calls[ЧастьДозапроса.index].function.arguments = мНакопленныйЗапрос.tool_calls[ЧастьДозапроса.index].function.arguments + ЧастьДозапроса.function.arguments;
		КонецЦикла;
	КонецЕсли;
КонецПроцедуры

// Инструменты

Функция ОбработатьВызовИнструмента(Знач СообщениеИИ, Знач УИДОтвета = "") Экспорт
	Если Не мЛиВключитьИнструменты Тогда
		Возврат Ложь;
	КонецЕсли;
	мКонтекстВызоваИнструментов.Итерация = мКонтекстВызоваИнструментов.Итерация + 1;
	Если мКонтекстВызоваИнструментов.Итерация > 5 Тогда
		ирОбщий.СообщитьЛкс("Превышен лимит итераций вызова инструментов");
		Возврат Ложь;
	КонецЕсли;
	ОтветыИнструментов = Новый Массив;
	Для Каждого ВызовИнструмента Из СообщениеИИ.tool_calls Цикл
		ИмяИнструмента = ВызовИнструмента.function.name;
		Аргументы = ВызовИнструмента.function.arguments;
		ПредставлениеРезультата = "";
		Попытка
			РезультатИнструмента = ВызватьИнструмент(ИмяИнструмента, Аргументы, ПредставлениеРезультата);
			Если РезультатИнструмента = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			Если ТипЗнч(РезультатИнструмента) = Тип("Строка") Тогда
				ТекстРезультата = РезультатИнструмента;
			Иначе
				ТекстРезультата = ирОбщий.ОбъектВТекстЖСОНЛкс(РезультатИнструмента);
			КонецЕсли;
		Исключение
			ТекстРезультата = ирОбщий.СтрШаблонЛкс("Ошибка выполнения %1: %2", ИмяИнструмента, ОписаниеОшибки());
		КонецПопытки;
		ЕстьОтветы = Истина;
		ОтветИнструмента = Новый Структура;
		ОтветИнструмента.Вставить("tool_call_id", ВызовИнструмента.id);
		//ОтветИнструмента.Вставить("role", "tool");
		ЛиОбработанКлиентом = ЗначениеЗаполнено(ТекстРезультата);
		Если ЛиОбработанКлиентом Тогда
			ОтветИнструмента.Вставить("content", ТекстРезультата);
			ОтветИнструмента.Вставить("status", "rejected"); // Для серверного инструмента Напарника
		Иначе
			ОтветИнструмента.Вставить("content", Неопределено);
			ОтветИнструмента.Вставить("status", "accepted"); // Для серверного инструмента Напарника
		КонецЕсли;
		ОтветИнструмента.Вставить("name", ИмяИнструмента);
		ОтветыИнструментов.Добавить(ОтветИнструмента);
		ОписаниеДозапроса = НовоеОписаниеДозапроса(Аргументы, ИмяИнструмента, ТекстРезультата, ЛиОбработанКлиентом, ПредставлениеРезультата);
		ВывестиДозапросВТекст(ОписаниеДозапроса);
		мКонтекстВызоваИнструментов.Дозапросы.Добавить(ОписаниеДозапроса);
	КонецЦикла;
	Если ОтветыИнструментов.Количество() = 0 Тогда
		Возврат Ложь;
	КонецЕсли;
	ОтменитьЗапрос(); // Текущий отменяем. Один запрос одновременно.
	ОтправитьЗапросИИ(ОтветыИнструментов,,,,, мЛиПотоковый,,,,,,, Истина, УИДОтвета);
	Возврат Истина;
КонецФункции

Процедура ВывестиДозапросВТекст(Знач ОписаниеДозапроса) Экспорт
	АргументыТекстом = ?(ТипЗнч(ОписаниеДозапроса.аргументы) = Тип("Строка"), ОписаниеДозапроса.Аргументы, ирОбщий.ОбъектВТекстЖСОНЛкс(ОписаниеДозапроса.аргументы));
	АргументыТекстом = ирОбщий.ПредставлениеСОбрезкойДлиныЛкс(АргументыТекстом);
	ПредставлениеДозапроса = "<small>//дозапрос " + ?(ОписаниеДозапроса.ЛиОбработанКлиентом, "(клиент)", "(сервер)") + " " + ОписаниеДозапроса.Инструмент + "(" + АргументыТекстом + ")";
	Если ЗначениеЗаполнено(ОписаниеДозапроса.ПредставлениеРезультата) Тогда
		ПредставлениеДозапроса = ПредставлениеДозапроса + " - " + ОписаниеДозапроса.ПредставлениеРезультата;
	КонецЕсли;
	Если ОписаниеДозапроса.ОтправленоСимволов > 1000 Тогда
		ПредставлениеДозапроса = ПредставлениеДозапроса + " - "+ ОписаниеДозапроса.ОтправленоСимволов + " символов";
	КонецЕсли;
	ПредставлениеДозапроса = ПредставлениеДозапроса + "</small>";
	Если ЗначениеЗаполнено(мНакопленныйОтвет) Тогда
		ПредставлениеДозапроса = Символы.ПС + ПредставлениеДозапроса;
	КонецЕсли;
	мНакопленныйОтвет = мНакопленныйОтвет + ПредставлениеДозапроса;
КонецПроцедуры

//.
// Параметры:
//   Аргументы -  - 
//   ИмяИнструмента -  - 
//   ТекстРезультата - Произвольный, Строка - 
// Возвращаемое значение:
//    - 
Функция НовоеОписаниеДозапроса(Знач Аргументы, Знач ИмяИнструмента, Знач ТекстРезультата, Знач ЛиОбработанКлиентом, Знач ПредставлениеРезультата) Экспорт
	Результат = Новый Структура("Инструмент, Аргументы, ОтправленоСимволов, ЛиОбработанКлиентом, ПредставлениеРезультата", ИмяИнструмента, Аргументы, СтрДлина(ТекстРезультата), ЛиОбработанКлиентом, ПредставлениеРезультата);
	Возврат Результат;
КонецФункции

