				Новый Структура("type,properties,required",
					"object",
					Новый Структура("module_name,method_name",
						Новый Структура("type,description", "string", "Полное имя модуля"),
						Новый Структура("type,description", "string", "Имя метода")
						),
					Новый Массив
					)
				));
				
	// Напарник
	Инструменты.Добавить(НовоеОписаниеИнструмента(
				"mcp__syntax-checker__validate", // Прошито в Напарнике. Он не хочет другие имена использовать.
				"Проверка кода",
				Новый Структура("type,properties,required",
					"object",
					Новый Структура("code, use_context",
						Новый Структура("type,description", "string", "текст программы"),
						Новый Структура("type,description", "boolean", "использовать текущий контекст модуля")
						),
					Новый Массив
					)
				));
	Инструменты.Добавить(НовоеОписаниеИнструмента(
				"GetProjects", // Прошито в Напарнике. Он не хочет другие имена использовать.
				"Список проектов",
				));
	
	Возврат Инструменты;
КонецФункции

Функция НовоеОписаниеИнструмента(Знач Имя, Знач Описание, Знач ПараметрыЖСОН)
	Возврат Новый Структура("type,function",
			"function",
			Новый Структура("name,description,parameters", Имя, Описание, ПараметрыЖСОН)
			);
КонецФункции

Функция ВызватьИнструмент(Знач ИмяИнструмента, Знач Аргументы, ПредставлениеРезультата = "")
	Если мПолеТекстаПрограммы.мПлатформа = Неопределено Тогда
		мПолеТекстаПрограммы.ИнициироватьНеинтерактивно();
	КонецЕсли;
	// Аргументы приходит как Структура (если распарсили) либо как строка JSON
	Если ТипЗнч(Аргументы) = Тип("Строка") И ирОбщий.ЛиТекстJSONЛкс(Аргументы) Тогда
		Аргументы = ирОбщий.ОбъектИзТекстаЖСОНЛкс(Аргументы);
	КонецЕсли;
	Если Аргументы = Неопределено Тогда
		Аргументы = Новый Структура;
	КонецЕсли;
	Если ИмяИнструмента = "platform_list_objects" Тогда
		Возврат Инструмент_ПлатформаСписокОбъектов(Аргументы);
	ИначеЕсли ИмяИнструмента = "platform_object" Тогда
		Возврат Инструмент_ПлатформаОписаниеОбъекта(Аргументы);
	ИначеЕсли ИмяИнструмента = "platform_object_member" Тогда
		Возврат Инструмент_ПлатформаОписаниеСлова(Аргументы);
	ИначеЕсли ИмяИнструмента = "metadata_list_objects" Тогда
		Возврат Инструмент_МетаданныеСписокОбъектов(Аргументы);
	ИначеЕсли ИмяИнструмента = "metadata_list_common_modules" Тогда
		Возврат Инструмент_МетаданныеСписокОбщихМодулей();
	ИначеЕсли ИмяИнструмента = "metadata_object" Тогда
		Возврат Инструмент_МетаданныеОписаниеОбъекта(Аргументы.full_name);
	ИначеЕсли ИмяИнструмента = "metadata_form" Тогда
		Возврат Инструмент_ОписаниеФормы(Аргументы.full_name);
	ИначеЕсли ИмяИнструмента = "module_list_methods" Тогда
		Возврат Инструмент_СписокМетодов(Аргументы);
	ИначеЕсли ИмяИнструмента = "module_method" Тогда
		Возврат Инструмент_ОписаниеМетода(Аргументы);
	// EDT - похоже просто дублирует запущенные на сервере сессии инструментов, чтобы клиент мог показать индикаторы
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "GetProjects", Истина) Тогда
		Возврат ирОбщий.ЗначенияВМассивЛкс(Метаданные.Имя);
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "FindSimilar_in_Project", Истина) Тогда
		// Аргументы.synthetic_call_key = "Справочник Скидки";
		// Аргументы.synthetic_call_key = "CommonModules.*.СортироватьМассив";
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "Search_Documentation", Истина) Тогда
		// Аргументы.query = "Методы сортировки массива Сортировать";
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "SearchText", Истина) Тогда
		// Аргументы.query = "Методы сортировки массива Сортировать";
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "Search_ITS", Истина) Тогда
		// Аргументы.query = "Методы сортировки массива Сортировать";
		Возврат "";
	ИначеЕсли ирОбщий.СтрКончаетсяНаЛкс(ИмяИнструмента, "SearchFiles", Истина) Тогда
		// Аргументы.query = "Методы сортировки массива Сортировать";
		Возврат "";
	ИначеЕсли ИмяИнструмента = "mcp__syntax-checker__validate" Тогда
		АнализаторКода = мПолеТекстаПрограммы.КопияКомпоненты();
		АнализаторКода.УстановитьТекст(Аргументы.code);
		АнализаторКода.ПроверитьВыраженияТекста(,,,,, Ложь);
		ТаблицаОшибок = АнализаторКода.ОшибкиМодуля.Выгрузить(, "ВыражениеРодитель, Позиция, Слово, ТипОшибки, ТипРодителя");
		Если ТаблицаОшибок.Количество() = 0 Тогда
			ПредставлениеРезультата = "Ошибок не найдено";
			Возврат ПредставлениеРезультата; // - Чтобы серверная проверка не выполнялась, нужен непустой результат
		Иначе
			мНакопленныйОтвет = "";
			ПредставлениеРезультата = ирОбщий.СтрШаблонЛкс("Найдено %1 ошибок, текст очищен", ТаблицаОшибок.Количество());
			Возврат ирОбщий.ТаблицаЗначенийВМассивЛкс(ТаблицаОшибок);
		КонецЕсли;
	Иначе
		//ВызватьИсключение "ИИ запросил неизвестный инструмент: " + ИмяИнструмента;
		Возврат "";
	КонецЕсли;
КонецФункции 

Функция Инструмент_СписокМетодов(Знач Аргументы) Экспорт
	Структура = Новый Структура;
	Если Аргументы.exportedOnly Тогда
		Структура.Вставить("ЛиЭкспорт", Истина);
	КонецЕсли;
	МодульПоИмени = МодульПоИмени(Аргументы.module_name);
	Массив = МодульПоИмени.Методы.Скопировать(Структура).ВыгрузитьКолонку("Имя");
	Возврат Массив;
КонецФункции

Функция МодульПоИмени(Знач ИмяМодуля) Экспорт
	МодульПоИмени = мПлатформа.ПолеТекстаМодуля(ИмяМодуля).мМодульМетаданных;
	Возврат МодульПоИмени;
КонецФункции

Функция Инструмент_ОписаниеМетода(Знач Аргументы) Экспорт
	МодульПоИмени = МодульПоИмени(Аргументы.module_name);
	СтрокаМетода = МодульПоИмени.Методы.Найти(НРег(Аргументы.method_name), "НИмя");
	Результат = мПолеТекстаПрограммы.МетодНапарника(СтрокаМетода, Аргументы.module_name);
	Возврат Результат;
КонецФункции

Функция Инструмент_ПлатформаСписокОбъектов(Знач Аргументы)
	Отбор = Новый Структура("ЯзыкПрограммы", 0);
	Возврат мПлатформа.ТаблицаОбщихТипов.Скопировать(Отбор).ВыгрузитьКолонку("БазовыйТип");
КонецФункции

Функция Инструмент_ПлатформаОписаниеОбъекта(Знач Аргументы)
	ОписаниеОбщегоТипа = мПлатформа.ОписаниеОбщегоТипа(Аргументы.name,, Истина);
	Таблица = мПлатформа.ТаблицаКонтекстов.Скопировать(Новый Структура("ТипКонтекста, ЯзыкПрограммы", ОписаниеОбщегоТипа.Слово, 0), "Слово, ТипСлова");
	//СинтаксПомощник = Обработки.ирСинтаксПомощник.Создать();
	//Результат = СинтаксПомощник.ТекстовоеОписаниеСлова(ОписаниеОбщегоТипа);
	Результат = ирОбщий.СтруктураИзСтрокиТаблицыИлиДереваИлиВыборкиЛкс(ОписаниеОбщегоТипа);
	Результат.Вставить("Члены", ирОбщий.ТаблицаЗначенийВМассивЛкс(Таблица));
	Возврат Результат;
КонецФункции

Функция Инструмент_ПлатформаОписаниеСлова(Знач Аргументы)
	ПолноеИмяСлова = Аргументы.full_name;
	Если ПустаяСтрока(ПолноеИмяСлова) Тогда
		ВызватьИсключение "full_name не задан";
	КонецЕсли;
	ЛиМетод = Аргументы.isMethod;
	ТипКонтекста = "Глобальный";
	Если Найти(ПолноеИмяСлова, ".") Тогда
		ТипКонтекста = ирОбщий.ПервыйФрагментЛкс(ПолноеИмяСлова);
	КонецЕсли;
	Слово = ирОбщий.ПоследнийФрагментЛкс(ПолноеИмяСлова);
	Отбор = Новый Структура("ТипКонтекста, Слово, ЯзыкПрограммы", ТипКонтекста, Слово, 0);
	СтрокаСлова = мПлатформа.ТаблицаКонтекстов.НайтиСтроки(Отбор)[0];
	СинтаксПомощник = Обработки.ирСинтаксПомощник.Создать();
	Результат = СинтаксПомощник.ТекстовоеОписаниеСлова(СтрокаСлова);
	Возврат Результат;
КонецФункции

Функция Инструмент_МетаданныеСписокОбъектов(Знач Аргументы)
	Типы = Неопределено;
	Если ЗначениеЗаполнено(Аргументы) Тогда
		Типы = ирОбщий.СвойствоСтруктурыЛкс(Аргументы, "types");
	КонецЕсли;
	Если Типы = Неопределено Или Типы.Количество() = 0 Тогда
		Типы = ирКэш.ТипыМетаОбъектов(Истина, Ложь, Истина).ВыгрузитьКолонку("Множественное");
	КонецЕсли;
	Результат = Новый Массив;
	Для Каждого ИмяКоллекции Из Типы Цикл
		Если ИмяКоллекции = "Перерасчеты" Тогда
			Продолжить;
		КонецЕсли;
		Коллекция = Метаданные[ИмяКоллекции];
		Для Каждого ОбъектМД Из Коллекция Цикл // ОбъектМетаданных
			Значение = Новый Структура;
			//Значение.Вставить("type", ИмяКоллекции);
			Значение.Вставить("name", ОбъектМД.Имя);
			Значение.Вставить("full_name", ОбъектМД.ПолноеИмя());
			Результат.Добавить(Значение);
		КонецЦикла;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция Инструмент_МетаданныеСписокОбщихМодулей()
	Результат = Новый Массив;
	Для Каждого МД Из Метаданные.ОбщиеМодули Цикл
		Структура = Новый Структура;
		Структура.Вставить("name", МД.Имя);
		Структура.Вставить("global", МД.Глобальный);
		Структура.Вставить("server", МД.Сервер);
		Структура.Вставить("serverCall", МД.ВызовСервера);
		Структура.Вставить("сashMode", МД.ПовторноеИспользованиеВозвращаемыхЗначений);
		Структура.Вставить("clientOrdinary", МД.КлиентОбычноеПриложение);
		Структура.Вставить("clientManaged", МД.КлиентУправляемоеПриложение);
		Результат.Добавить(Структура);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция Инструмент_MetadataListCommonForms()
	Результат = Новый Массив;
	Для Каждого МД Из Метаданные.ОбщиеФормы Цикл
		Результат.Добавить(Новый Структура("name", МД.Имя));
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция Инструмент_МетаданныеОписаниеОбъекта(Знач ПолноеИмяМД)
	Если ПустаяСтрока(ПолноеИмяМД) Тогда
		ВызватьИсключение "full_name не задан";
	КонецЕсли;
	ОбъектМД = Метаданные.НайтиПоПолномуИмени(ПолноеИмяМД);
	Структура = мПолеТекстаПрограммы.ОбъектМДНапарника(ОбъектМД);
	Возврат Структура;
КонецФункции

Функция Инструмент_ОписаниеФормы(Знач ПолноеИмяФормы)
