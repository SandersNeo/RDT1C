Функция Браузер() Экспорт
	Возврат мБраузер._1CAPI; /// Добавка нужна для поддержки 8.3.25-
КонецФункции

// Ответ нужно ловить в обработчике onclick браузера.
// Отменяет текущий активный запрос.
// Параметры:
//   Адрес - Строка -
//   ТелоЗапросаСтрока - Строка -
//   Заголовки - Соответствие -
Процедура ОтправитьЗапрос(Знач Адрес, Знач ТелоЗапросаСтрока, Знач Заголовки, Знач ЛиПотоковый = Ложь, Знач ЛиПроверочный = Ложь, знач МинИнтервалОтветов = 500, Знач ЛиДозапрос = Ложь) Экспорт
	Если Не ирКэш.ДоступноБраузерWebKitЛкс() Тогда
		Возврат;
	КонецЕсли;
	мЛиПроверочный = ЛиПроверочный;
	ЗаголовкиМассив = Новый Массив;
	Для Каждого ЗаголовкиЭлемент Из Заголовки Цикл
		ЗаголовкиМассив.Добавить(Новый Структура("name,value", ЗаголовкиЭлемент.Ключ, ЗаголовкиЭлемент.Значение));
	КонецЦикла;
	ЗаголовкиТекст = ирОбщий.ОбъектВТекстЖСОНЛкс(ЗаголовкиМассив);
	Если Не ЛиДозапрос Тогда
		мНакопленныйОтвет = "";
	ИначеЕсли ЗначениеЗаполнено(мНакопленныйОтвет) Тогда
		мНакопленныйОтвет = мНакопленныйОтвет + Символы.ПС;
	КонецЕсли;
	мНакопленныйЗапрос = Неопределено;
	мЛиПотоковый = ЛиПотоковый;
	Если мЛиПотоковый Тогда
		Браузер().sendStreamRequest(Адрес, ТелоЗапросаСтрока, ЗаголовкиТекст, МинИнтервалОтветов);
	Иначе
		Браузер().sendHttpRequest(Адрес, ТелоЗапросаСтрока, ЗаголовкиТекст);
	КонецЕсли;
КонецПроцедуры

Функция ЛиПотокЗавершен() Экспорт
	Возврат Браузер().isStreamCompleted();
КонецФункции

// Не поддерживает поток
Функция ЛиЗапросВыполняется() Экспорт
	Возврат Браузер().isActiveHttpRequest();
КонецФункции

Функция СтатусЗапроса() Экспорт
	Возврат Браузер().getRequestStatus();
КонецФункции

// Читает и удаляет полученную часть ответа
Функция ПрочитатьЧастьОтвета() Экспорт
	Возврат Браузер().getAndClearAllData();
КонецФункции

Процедура ОтменитьЗапрос() Экспорт
	Если Не ирКэш.ДоступноБраузерWebKitЛкс() Тогда
		Возврат;
	КонецЕсли;
	Браузер().cancelCurrentRequest();
КонецПроцедуры

// Отправляет запрос к ИИ через OpenAPI. Ответ приходит событием onclick
// Параметры:
//   ПараметрыЗапроса - Структура, Массив - Содержимое сообщения, Массив для дозапросов
//    *Текст - Строка - текст запроса
//   Форма - Форма -
//   ОбработчикОтвета -  -
//   БлокируемыеЭлементы -  -
//   Кнопка - Кнопка -
//   ЛиПроверочный - Булево -
//   РежимНапарника - Строка - docstring, explain, review, modify, custom, system, raw
//   КлючСервиса - Строка - Ключ API для аутентификации
//   Сервер - Строка - URL-адрес API, опционально, по умолчанию - OpenRouter
//   Модель - Строка - Название модели, опционально, по умолчанию - deepseek/deepseek-chat
// Возвращаемое значение:
//   Булево - успешность запуска
Функция ОтправитьЗапросИИ(Знач ПараметрыЗапроса, Знач Форма = Неопределено, Знач ОбработчикОтвета = "", Знач БлокируемыеЭлементы = Неопределено, Знач Кнопка = Неопределено,
		Знач ЛиПотоковый = Ложь, Знач ЛиПроверочный = Ложь, Знач РежимНапарника = "custom", Знач КлючСервиса = Неопределено, Знач Сервер = Неопределено, Знач Модель = Неопределено,
		Знач ПараметрыМоделиИИ = Неопределено, Знач ВключитьИнструменты = Ложь, Знач УИДОтвета = Неопределено) Экспорт
	Если Не ирКэш.ДоступноБраузерWebKitЛкс() Тогда
		ирОбщий.СообщитьЛкс("Для отправки запроса к ИИ требуется платформа 8.3.14+");
		Возврат Ложь;
	КонецЕсли;
	Сервер = мПлатформа.СерверИИ(, Сервер);
	Модель = мПлатформа.МодельИИ(, Модель, Сервер);
	Если Ложь
		Или КлючСервиса = Неопределено
		Или КлючСервиса = "" И мПлатформа.ЛиНапарникВРолиОбщегоИИ(Сервер)
	Тогда
		КлючСервиса = мПлатформа.КлючСервисаИИ(Сервер);
	КонецЕсли;
	Если ПустаяСтрока(КлючСервиса) Тогда
		Если Не ЛиПроверочный Тогда
			#Если Клиент Тогда
				Форма = ирКлиент.ОткрытьНастройкиПоляПрограммыЛкс("", Истина, "КлючСервисаИИ");
			#КонецЕсли
		КонецЕсли;
		ВызватьИсключение "Не указан ключ сервиса ИИ";
	КонецЕсли;
	ЛиДозапрос = УИДОтвета <> Неопределено;
	Если мОписаниеЗадания <> Неопределено Тогда
		ОтменитьЗапрос();
		Если Не ЛиДозапрос Тогда
			ирКлиент.ОтменитьЗаданиеФормыЛкс(Форма, мОписаниеЗадания);
			мОписаниеЗадания = Неопределено;
			Возврат Ложь;
		КонецЕсли;
	КонецЕсли;
	Если ЛиДозапрос Тогда
		Роль = "tool";
	Иначе
		Роль = "user";
		мОписаниеЗадания = ирКлиент.ОписаниеФоновогоЗаданияФормыЛкс("ЗапросИИ",, ПараметрыЗапроса,, Кнопка, ОбработчикОтвета,,, БлокируемыеЭлементы,,,,, Ложь);
		ирКлиент.ЗапуститьИлиОтменитьФоновоеЗаданиеФормыЛкс(Форма, мОписаниеЗадания);
	КонецЕсли; 
	мЛиВключитьИнструменты = ВключитьИнструменты;
	Если Сервер = "https://code.1c.ai" Тогда
		// Для анализа трафика EDT Импорт сертификата Fiddler: 
		// keytool.exe -import -alias fiddler -file "%USERPROFILE%\Desktop\FiddlerRoot.cer" -keystore "C:\Program Files\1C\1CE\components\<jdk>\lib\security\cacerts" -storepass changeit -noprompt
		//Если РежимНапарника = "custom" Тогда
		//КонецЕсли;
		ПолеТекстаПрограммы = ирКэш.ПолеТекстаПрограммы();
		Соединение = ПолеТекстаПрограммы.СоединениеНапарника();
		Если ТипЗнч(Соединение) = Тип("Строка") Тогда
			ирОбщий.СообщитьЛкс(ирОбщий.СтрШаблонЛкс("Ошибка соединения с Напарником: %1", Соединение));
			ирКлиент.ОтменитьЗаданиеФормыЛкс(Форма, мОписаниеЗадания);
			мОписаниеЗадания = Неопределено;
			Возврат Ложь;
		КонецЕсли;
		Заголовки = ПолеТекстаПрограммы.ЗаголовкиЗапросаНапарника(КлючСервиса);
		Если ЛиДозапрос Тогда
			Содержание = ПараметрыЗапроса;
		Иначе
			ПараметрыЧатаНапарника = Новый Структура;
			ПараметрыЧатаНапарника.Вставить("instruction", ПараметрыЗапроса.Текст);
			ПараметрыЧатаНапарника.Вставить("tools");
			Если мЛиВключитьИнструменты Тогда
				// Похоже он использует только фиксированные имена инструментов
				ПараметрыЧатаНапарника.Вставить("tools", СписокИнструментов());
			КонецЕсли;
			Запрос = ирОбщий.ЗапросHTTPЛкс("/chat_api/v1/conversations/");
			Запрос.Заголовки = Заголовки;
			СтруктураЗапроса = Новый Структура;
			СтруктураЗапроса.Вставить("tool_name", РежимНапарника);
			СтруктураЗапроса.Вставить("skill_name", РежимНапарника);
			СтруктураЗапроса.Вставить("is_chat", Истина);
			СтруктураЗапроса.Вставить("programming_language", "1с");
			СтруктураЗапроса.Вставить("ui_language", "russian");
			СтруктураЗапроса.Вставить("script_language", ПолеТекстаПрограммы.ИмяЯзыкаЧеловека());
			Запрос.УстановитьТелоИзСтроки(ирОбщий.ОбъектВТекстЖСОНЛкс(СтруктураЗапроса));
			Ответ = Соединение.ОтправитьДляОбработки(Запрос);
			Если Не ирОбщий.ЛиУспешныйОтветHTTPЛкс(Ответ) Тогда
				ирОбщий.СообщитьЛкс(ирОбщий.СтрШаблонЛкс("Ошибка %1: %2", Ответ.КодСостояния, Ответ.ПолучитьТелоКакСтроку()));
				ирКлиент.ОтменитьЗаданиеФормыЛкс(Форма, мОписаниеЗадания);
				мОписаниеЗадания = Неопределено;
				Возврат Ложь;
			КонецЕсли;
			СтруктураОтвета = ирОбщий.ОбъектИзТекстаЖСОНЛкс(Ответ.ПолучитьТелоКакСтроку()); // см. ПрочитатьJSON(ОбразецОтветаСозданияЧатаНапарника())
			Адрес = "https://code.1c.ai/chat_api/v1/conversations/" + СтруктураОтвета.uuid + "/messages";
			Содержание = Новый Структура("content", ПараметрыЧатаНапарника);
		КонецЕсли;
		СтруктураЗапроса = Новый Структура;
		//"tool_content": ...
		СтруктураЗапроса.Вставить("role", Роль);
		СтруктураЗапроса.Вставить("parent_uuid", УИДОтвета);
		//СтруктураЗапроса.Вставить("tool_content", ПараметрыЗапроса);
		СтруктураЗапроса.Вставить("content", Содержание);
	Иначе
		Заголовки = Новый Соответствие;
		Заголовки.Вставить("Content-Type", "application/json");
		//Заголовки.Вставить("Origin", "https://chat.deepseek.com");
		//Заголовки.Вставить("Referer", "https://chat.deepseek.com/");
		Если ЗначениеЗаполнено(КлючСервиса) Тогда
			Заголовки.Вставить("Authorization", "Bearer " + КлючСервиса);
		КонецЕсли;
		СтруктураЗапроса = Новый Структура;
		СтруктураЗапроса.Вставить("model", Модель);
		Если ЛиДозапрос Тогда
			СтруктураЗапроса.Вставить("messages", мКонтекстВызоваИнструментов.Сообщения);
			Содержание = ПараметрыЗапроса;
		Иначе
			СтруктураЗапроса.Вставить("messages", Новый Массив);
			Если мЛиВключитьИнструменты Тогда
				//ЛиПотоковый = Ложь; // - Пока только в непотоковом режиме, чтобы не усложнять парсинг
				СтруктураЗапроса.Вставить("tools", СписокИнструментов());
				СтруктураЗапроса.Вставить("tool_choice", "auto");
			КонецЕсли;
			Содержание = ПараметрыЗапроса.Текст;
		КонецЕсли;
		СтруктураЗапроса.Вставить("stream", ЛиПотоковый);
		Если ПараметрыМоделиИИ = Неопределено Тогда
			ПараметрыМоделиИИ = мПлатформа.ПараметрыМоделиИИ();
		КонецЕсли;
		Для Каждого ЭлементСписка Из ПараметрыМоделиИИ Цикл
			Если Не ЭлементСписка.Пометка Тогда
				Продолжить;
			КонецЕсли;
			Если Не ирОбщий.ЛиИмяПеременнойЛкс(ЭлементСписка.Представление) Тогда
				ирКлиент.ОткрытьНастройкиПоляПрограммыЛкс("", Истина, "ПараметрыМоделиИИ");
				ВызватьИсключение ирОбщий.СтрШаблонЛкс("Неверное имя параметра модели ИИ: %1", ЭлементСписка.Представление);
			КонецЕсли;
			ЗначениеПараметра = ЭлементСписка.Значение;
			Если ЭлементСписка.Представление = "reasoning" Тогда
				ЗначениеПараметра = Новый Структура("enable", ЗначениеПараметра);
			КонецЕсли;
			СтруктураЗапроса.Вставить(ЭлементСписка.Представление, ЗначениеПараметра);
		КонецЦикла;
		СтруктураСообщения = Новый Структура("role,content", Роль, Содержание);
		СтруктураЗапроса.messages.Добавить(СтруктураСообщения);
		Адрес = Сервер + "/v1/chat/completions";
	КонецЕсли;
	Если ЛиДозапрос Тогда
		Адрес = мКонтекстВызоваИнструментов.Адрес;
	Иначе
		мКонтекстВызоваИнструментов = НовыйКонтекстВызоваИнструментов(Заголовки, Адрес);
	КонецЕсли;
	ОтправитьЗапрос(Адрес, ирОбщий.ОбъектВТекстЖСОНЛкс(СтруктураЗапроса), Заголовки, ЛиПотоковый, ЛиПроверочный,, ЛиДозапрос);
	мКонтекстВызоваИнструментов.Сообщения.Добавить(СтруктураСообщения);
	Возврат Истина;
КонецФункции

Функция НовыйКонтекстВызоваИнструментов(Знач Заголовки, Знач Адрес) Экспорт
	КонтекстВызоваИнструментов = Новый Структура;
	КонтекстВызоваИнструментов.Вставить("Заголовки", Заголовки);
	КонтекстВызоваИнструментов.Вставить("Сообщения", Новый Массив);
	КонтекстВызоваИнструментов.Вставить("Итерация", 0);
	КонтекстВызоваИнструментов.Вставить("Адрес", Адрес);
	КонтекстВызоваИнструментов.Вставить("Дозапросы", Новый Массив); // Массив из см. НовоеОписаниеДозапроса
	Возврат КонтекстВызоваИнструментов;
КонецФункции

